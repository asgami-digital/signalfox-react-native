{
  "name": "@asgami-digital/signalfox-react-native",
  "version": "1.0.1",
  "description": "React Native SDK for SignalFox analytics",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "types",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace @asgami/signalfox-rn-revenuecat start",
    "example:rn-revenuecat": "yarn workspace @asgami/signalfox-rn-revenuecat start",
    "example:rn-revenuecat:ios": "yarn workspace @asgami/signalfox-rn-revenuecat ios",
    "example:rn-revenuecat:android": "yarn workspace @asgami/signalfox-rn-revenuecat android",
    "example:expo-rniap": "yarn workspace expo-rniap start",
    "example:expo-rniap:ios": "yarn workspace expo-rniap ios",
    "example:expo-rniap:android": "yarn workspace expo-rniap android",
    "clean": "del-cli android/build examples/rn-revenuecat/android/build examples/rn-revenuecat/android/app/build examples/rn-revenuecat/ios/build lib",
    "prepare": "bob build && node ./scripts/ensure-rn-augmentation-in-lib-types.mjs",
    "typecheck": "tsc",
    "test": "jest",
    "release": "release-it --only-version",
    "lint": "eslint \"**/*.{js,ts,tsx}\""
  },
  "keywords": [
    "react-native",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asgami-digital/signalfox-react-native.git"
  },
  "author": "Asgami <arturo.sancho@asgami.com> (https://asgami.com)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/asgami-digital/signalfox-react-native/issues"
  },
  "homepage": "https://github.com/asgami-digital/signalfox-react-native#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/compat": "^1.3.2",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.35.0",
    "@react-native/babel-preset": "0.83.0",
    "@react-native/eslint-config": "0.83.0",
    "@release-it/conventional-changelog": "^10.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19",
    "commitlint": "^19.8.1",
    "del-cli": "^6.0.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^29.7.0",
    "lefthook": "^2.0.3",
    "prettier": "^2.8.8",
    "react": "19.2.0",
    "react-native": "0.83.0",
    "react-native-builder-bob": "^0.40.18",
    "react-test-renderer": "19.2.0",
    "release-it": "^19.0.4",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-purchases": ">= 6.0.0"
  },
  "peerDependenciesMeta": {
    "react-native-purchases": {
      "optional": true
    }
  },
  "workspaces": [
    "examples/rn-revenuecat",
    "examples/expo-rniap"
  ],
  "packageManager": "yarn@4.14.1",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "SignalfoxReactNativeSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.asgami.signalfoxreactnative"
    }
  },
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/examples/.*/node_modules",
      "<rootDir>/lib/"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "angular"
        }
      }
    }
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "create-react-native-library": {
    "type": "turbo-module",
    "languages": "kotlin-objc",
    "tools": [
      "jest",
      "lefthook",
      "release-it",
      "eslint"
    ],
    "version": "0.57.2"
  }
}
